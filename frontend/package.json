{
  "name": "mtb-gui",
  "version": "0.1.0",
  "license" : "AGPL-3.0-only; SEE LICENSE IN ./../LICENSE",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --ignore-pattern src/gen/**",
    "fix-lint": "eslint . --ext ts,tsx --report-unused-disable-directives --ignore-pattern src/gen/** --fix",
    "prettier": "prettier . -l",
    "fix-prettier": "prettier --write .",
    "gen-build": "npm run generate-sources && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "generate-sources": "openapi-generator-cli generate -g typescript-axios -i ./config/openapi.yaml -o ./src/gen/api",
    "analyze-bundle-size": "GENERATE_SOURCEMAP=true npm run build && source-map-explorer build/static/js/*.js"
  },
  "dependencies": {
    "@mui/icons-material": "^5.11.16",
    "@mui/lab": "^5.0.0-alpha.170",
    "@mui/material": "^5.15.10",
    "@mui/x-data-grid": "^6.19.4",
    "@mui/x-date-pickers": "^6.3.0",
    "axios": "^1.3.2",
    "axios-retry": "^4.5.0",
    "dayjs": "^1.11.7",
    "jwt-decode": "^3.1.2",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-hook-form": "^7.46.2",
    "react-oidc-context": "^2.2.2",
    "react-router-dom": "^6.10.0",
    "react-scripts": "^5.0.1",
    "react-to-print": "^2.14.15",
    "sass": "^1.62.0",
    "typescript": "^4.9.5",
    "use-deep-compare-effect": "^1.8.1",
    "uuid": "^9.0.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@hookform/devtools": "^4.3.1",
    "@openapitools/openapi-generator-cli": "^2.5.2",
    "source-map-explorer": "^2.5.3",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.11",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@types/uuid": "^9.0.8",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.3.3",
    "typescript-axios": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
